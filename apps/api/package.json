{
  "name": "@carnet/api",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "main": "./src/routers/_app.ts",
  "types": "./src/routers/_app.ts",
  "exports": {
    ".": "./src/routers/_app.ts"
  },
  "scripts": {
    "dev": "NODE_OPTIONS='--max-http-header-size=32768' tsx watch --env-file=.env src/server.ts",
    "build": "tsup",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:backup": "node scripts/db-backup.mjs",
    "db:restore": "node scripts/db-restore.mjs",
    "db:migrate": "pnpm db:backup && prisma migrate dev",
    "db:deploy": "pnpm db:backup && prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate",
    "db:reset": "pnpm db:backup && prisma migrate reset",
    "seed:media": "tsx --env-file=.env scripts/seed-media-test.ts",
    "cleanup:media": "tsx --env-file=.env scripts/cleanup-media-test.ts",
    "reset:password": "tsx --env-file=.env scripts/reset-password.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.173",
    "@anthropic-ai/sdk": "^0.104.1",
    "@aws-sdk/client-s3": "^3.1058.0",
    "@aws-sdk/lib-storage": "^3.1058.0",
    "@aws-sdk/s3-request-presigner": "^3.1058.0",
    "@carnet/schemas": "workspace:*",
    "@fastify/cookie": "^11.0.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/helmet": "^12.0.1",
    "@fastify/rate-limit": "^10.2.1",
    "@fastify/static": "^9.1.3",
    "@prisma/client": "^5.22.0",
    "@trpc/server": "^11.0.0",
    "archiver": "^8.0.0",
    "argon2": "^0.41.1",
    "fastify": "^5.1.0",
    "node-cron": "^4.2.1",
    "otplib": "^13.4.0",
    "web-push": "^3.6.7",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/web-push": "^3.6.4",
    "pino-pretty": "^11.3.0",
    "prisma": "^5.22.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.9"
  }
}

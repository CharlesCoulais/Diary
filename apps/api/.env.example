# Copier ce fichier en .env et adapter
DATABASE_URL="postgresql://journal:journal@localhost:5433/journal?schema=public"
PORT=4100
NODE_ENV=development

# Secret pour signer les cookies. Générer avec :
# openssl rand -base64 48
COOKIE_SECRET="change-me-please-this-must-be-at-least-32-characters-long"

# Origine du frontend autorisée par CORS
WEB_ORIGIN="http://localhost:5200"

# LanguageTool (correcteur orthographe). Public : https://api.languagetool.org (20 req/min)
# ou self-host : docker run -d -p 8010:8010 erikvl87/languagetool puis http://localhost:8010
LANGUAGETOOL_URL=""

# Clé API Giphy (gratuite) pour la recherche de GIF dans la messagerie.
# Optionnelle : sans elle, l'onglet « GIF » du sélecteur est masqué.
# Obtenir une clé : https://developers.giphy.com/dashboard/
GIPHY_API_KEY=""

# Récap mensuel IA — via le plan Claude Max, aucun coût API.
# Générer le token avec : claude setup-token
# Optionnel : en dev, le login Claude Code local suffit (laisser vide).
# En prod (Railway), définir le token sinon la carte récap est masquée.
CLAUDE_CODE_OAUTH_TOKEN=""
# Modèle utilisé (alias Claude Code) : sonnet (défaut), haiku ou opus.
AI_TEXT_MODEL="sonnet"
